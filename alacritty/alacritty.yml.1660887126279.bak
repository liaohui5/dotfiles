#############################################################################
# docs: https://github.com/alacritty/alacritty/blob/master/alacritty.yml 
# themes: https://www.npmjs.com/package/alacritty-themes
#############################################################################

# 设置窗口
window:
  decorations: "buttonless" # full | buttonless, 设置为 buttonless 就不显示标题栏
  padding:
    x: 2
    y: 2

# 修改配置文件后立即生效
live_config_reload: true

# 如果为true，则使用亮色变体绘制粗体文本。
draw_bold_text_with_bright_colors: false

# 设置字体
font:
  normal:
    family: "Hack Nerd Font Mono"
    style: Regular
  bold:
    family: "Hack Nerd Font Mono"
    style: Bold
  italic:
    family: "Hack Nerd Font Mono"
    style: Italic
  bold_italic:
    family: "Hack Nerd Font Mono"
    style: Bold Italic

  # 字大小
  size: 16.0

  # y: 文字行高 x: 文字间距
  offset:
    x: 0
    y: 1

# 选中
# selection:
#   semantic_escape_chars: ',│`|:"'' ()[]{}<>'
#   save_to_clipboard: true

# 按键绑定
key_bindings:
  - { key: V, mods: command, action: Paste } # command + v
  - { key: C, mods: command, action: Copy }  # command + c
  - { key: T, mods: Alt, chars: "\x1bt"}     # alt + t
  - { key: H, mods: Alt, chars: "\x1bh"}     # alt + h
  - { key: J, mods: Alt, chars: "\x1bj"}     # alt + j
  - { key: K, mods: Alt, chars: "\x1bk"}     # alt + k
  - { key: L, mods: Alt, chars: "\x1bl"}     # alt + l
  - { key: I, mods: Alt, chars: "\x1bi"}     # alt + i
  - { key: N, mods: Alt, chars: "\x1bn"}     # alt + n

# 颜色主题
theme: One-Dark
colors:
  # Default colors
  primary:
    background: '#282c34'
    foreground: '#abb2bf'

  # Normal colors
  normal:
    # NOTE: Use '#131613' for the `black` color if you'd like to see
    # black text on the background.
    black: '#282c34'
    red: '#e06c75'
    green: '#98c379'
    yellow: '#d19a66'
    blue: '#61afef'
    magenta: '#c678dd'
    cyan: '#56b6c2'
    white: '#abb2bf'

  # Bright colors
  bright:
    black: '#5c6370'
    red: '#e06c75'
    green: '#98c379'
    yellow: '#d19a66'
    blue: '#61afef'
    magenta: '#c678dd'
    cyan: '#56b6c2'
    white: '#ffffff'
